{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id, user_id, name,\n            type as type_,\n            color, icon, sort_order, is_active,\n            created_at, updated_at\n        FROM categories\n        WHERE (user_id IS NULL OR user_id = $1)\n            AND is_active = TRUE\n        ORDER BY sort_order ASC, name ASC\n        ",
